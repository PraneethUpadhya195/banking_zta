# =========================
# 1. ENVIRONMENT VARIABLES (CRITICAL)
# =========================
.env
.env.*
*.local
.env.development.local
.env.test.local
.env.production.local

# =========================
# 2. PYTHON / BACKEND
# =========================
__pycache__/
*.py[cod]
*$py.class
venv/
env/
.venv/
.pytest_cache/
*.sqlite3

# =========================
# 3. NODE / FRONTEND (REACT/VITE)
# =========================
node_modules/
frontend/node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# =========================
